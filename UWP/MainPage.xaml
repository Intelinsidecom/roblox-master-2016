<Page
    x:Class="Client.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Client"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Black">
    <Grid>
        <SwapChainPanel x:Name="SwapChainPanel"/>
        <Grid x:Name="StartupMenu">
            <Grid.Background>
                <ImageBrush Stretch="UniformToFill" ImageSource="Assets/LandingPage/home_bkg.png"/>
            </Grid.Background>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image x:Name="image" Source="Assets/LandingPage/roblox_logo_red.png" d:LayoutOverrides="TopPosition, BottomPosition" HorizontalAlignment="Center" VerticalAlignment="Center" Height="85" Margin="50,0"/>
                <TextBlock Text="Roblox 2016 Rebrought to UWP by Intel and not AI."
                           Foreground="#AAAAAA"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>
                <Button x:Name="StartButton"
                        Content="Start Engine"
                        Background="White"
                        Foreground="Black"
                        FontSize="24"
                        Padding="5"
                        HorizontalAlignment="Center"
                        Click="OnStartClick" FontFamily="Microsoft Sans Serif" Margin="0" FontStretch="Undefined" Width="160" Height="60" UseLayoutRounding="True" BorderThickness="2" BorderBrush="Black"/>
            </StackPanel>
        </Grid>
        <Grid Width="800" Height="400"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="20"
              Background="#AA000000"
              IsHitTestVisible="False" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="#0074BD">
                <TextBlock Text="Log Output"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="Bold"
                           Margin="10,5,10,5"/>
                <Button Content="×"
                        Foreground="White"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="18"
                        Width="30"
                        Height="30"
                        HorizontalAlignment="Right"
                        IsTabStop="False"
                        Click="OnCloseLogClick"/>
            </Grid>
            <ScrollViewer Grid.Row="1"
                          x:Name="LogScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          IsTabStop="False"
                          Margin="5">
                <TextBox x:Name="LogTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="11"
                         Background="#1E1E1E"
                         Foreground="#DCDCDC"
                         BorderThickness="0"
                         IsTabStop="False"
                         Text=""/>
            </ScrollViewer>
        </Grid>
        <Grid x:Name="LoadingGrid" Margin="0" Background="#4C000000" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0*"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <ProgressRing IsActive="True"
                                  HorizontalAlignment="Center"
                                  Foreground="#0074BD" VerticalAlignment="Center" Margin="0,0,0,65" Height="50" Grid.Column="1" Width="50"/>
            <TextBlock Text="Loading"
                               FontSize="14"
                               Margin="0" Foreground="#FF212121" Padding="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="LoadingStatusText"
                               Text="Waiting..."
                               FontSize="12"
                               Margin="0,30,0,0" Foreground="Black" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Page>
